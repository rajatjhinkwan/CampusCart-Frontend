# Copy to .env for local development. On Vercel, set production values in Project Settings → Environment Variables.

# Production API (Render backend) — required for Vercel builds
VITE_API_BASE_URL=https://campuscart-backend-34qc.onrender.com

# Local dev only: leave unset to use Vite proxy (/api → backend). Override proxy target if backend runs elsewhere:
# VITE_API_DEV_URL=
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Google OAuth & Maps
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: geo proxy bases (defaults to backend /api/geo/* in production)
# VITE_PHOTON_PROXY_BASE=
# VITE_NOMINATIM_PROXY_BASE=
# VITE_OSRM_PROXY_BASE=
# VITE_NOMINATIM_CONTACT=contact@example.com

# Optional branding
# VITE_APP_LOGO_URL=
